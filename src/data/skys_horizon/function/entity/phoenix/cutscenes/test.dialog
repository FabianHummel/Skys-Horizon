participant phoenix:
    name: {text:"Phoenix",color:"#FAB100"}
    color: "#123456"

participant chance:
    name: {text:"Chance",color:"#4798f5"}

paragraph phoenix:
    text: "Hi!"

paragraph chance:
    text: "more text"
    sound: "skys_horizon:dialog.test"

paragraph chance:
    text: {text:"fancy text",color:"#000000"}

paragraph chance:
    text: "Slow text"
    rate: 0.5

paragraph phoenix:
    text: "wait... " 2s "nevermind!" 1s {text:"snbt text"}

option abc:
    name: "option 1"

    paragraph phoenix:
        text: "reply to option 1"

    paragraph chance:
        text: "some more text"

    option nice:
        name: "nice option"

        paragraph chance:
            text: "very cool"

    end choice

option abc:
    name: "option 2"

    paragraph phoenix:
        text: "reply to option 2"

    paragraph phoenix:
        text: "more text after reply"

end choice

paragraph phoenix:
    text: "end!"
