{
    "name": "Sky's Horizon",
    "description": "Venture through foreign tales, research advanced technology, seek friendship with the unknown in the world of Sky's Horizon.",
    "author": "Fabian Hummel",
    "ignore": [
        "instance"
    ],
    "data_pack": {
        "name": "Sky's Horizon",
        "load": [
            "src",
            "include/animated_java-datapack"
        ]
    },
    "resource_pack": {
        "name": "Sky's Horizon",
        "load": [
            "src",
            "include/animated_java-resourcepack"
        ]
    },
    "require": [
        "plugins.done_message",
        "plugins.objmc-rs",
        "plugins.marker_color",
        "plugins.dialog",
        "plugins.aseprite",
        "bookshelf.module.raycast"
    ],
    "pipeline": [
        "beet.contrib.log_level",
        "beet.contrib.livereload",
        "plugins.generate_auto_called_nested_functions",
        "plugins.inline_function_declaration",
        "plugins.icon"
    ],
    "meta": {
        "icon": "assets/logo/icon.png",
        "objmc": {
            "binary": "src/assets/objmc/target/release/objmc-rs",
            "models": {
                "skys_horizon:space/planet/sorax4b": 249,
                "skys_horizon:entity/phoenix": 238
            }
        },
        "log_level": {
            "level": "INFO"
        }
    }
}
